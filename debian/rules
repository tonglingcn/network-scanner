#!/usr/bin/make -f

# Uncomment this to turn on verbose mode.
# export DH_VERBOSE=1

# Use debhelper v13
%:
	dh $@

# Override build system steps
override_dh_auto_configure:
	dh_auto_configure -- -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr

override_dh_auto_build:
	dh_auto_build --verbose

override_dh_auto_install:
	dh_auto_install --destdir=debian/network-scanner
	# Install desktop file
	mkdir -p debian/network-scanner/usr/share/applications
	install -m 644 assets/network-scanner.desktop debian/network-scanner/usr/share/applications/
	# Install icon
	mkdir -p debian/network-scanner/usr/share/icons/hicolor/scalable/apps
	install -m 644 assets/icon.svg debian/network-scanner/usr/share/icons/hicolor/scalable/apps/network-scanner.svg
